#############################################
## Visual Studio IDE (Community/Pro/Enterprise)
#############################################
# User-specific files
*.rsuser
*.suo
*.user
*.userosscache
*.sln.docstates

# Build outputs and temporary artifacts
[Dd]ebug/
[Dd]ebugPublic/
[Rr]elease/
[Rr]eleases/
x64/
x86/
[Bb]in/
[Oo]bj/
bld/
build/

# Roslyn and internal IDE cache directories
.vs/
*.ide/

# Test results and logs
[Tt]est[Rr]esult*/
[Bb]uild[Ll]og.*
*.VisualState.xml
TestResult.xml

#############################################
## Visual Studio Code (VS Code)
#############################################
# Ignore the entire workspace configuration folder by default
.vscode/*

# EXCEPT for files that share project rules or tasks with your team
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
!.vscode/*.code-snippets

# Ignore individual or team workspace definitions
*.code-workspace

# Locally built extensions
*.vsix
